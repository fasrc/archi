# Real ServiceNow ticket data — operator-local only, never commit.
examples/benchmarking/snow_ragas_queries_pt1.json

# config/ is its own git repository and holds config/benchmarking/secrets.env;
# committing it would either break as a gitlink or leak the secret.
/config/

# Claude Code session state (worktrees, plans, memory, local settings).
# Ignore everything under .claude/ EXCEPT project-authored agents — shared,
# archi-specific subagents are institutional knowledge worth versioning. The
# worktrees (full repo checkouts), settings.local.json, and runtime locks stay out.
/.claude/*
!/.claude/agents/

# Ralph harness runtime state (machine-written; never committed)
.ralph/
/review-findings.md
.coverage
coverage.xml

# FASRC 'dev' deployment. Track the secret-free orchestration scripts and a
# sanitized example config so the deploy is reproducible and not bus-factor-1,
# but keep the real host-specific config, agent prompts, source manifests, and
# any secrets out. Default-deny: a future stray file under deploy/fasrc-dev/ is
# ignored unless explicitly allow-listed here.
deploy/fasrc-dev/*
!deploy/fasrc-dev/scripts
!deploy/fasrc-dev/config.example.yaml
# Defense-in-depth: never track secrets/env even under the allow-listed scripts dir.
deploy/fasrc-dev/scripts/**/*.env
deploy/fasrc-dev/scripts/**/*secret*
